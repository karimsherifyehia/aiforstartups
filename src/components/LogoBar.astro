const doubled = [...integrations, ...integrations];
---

<section class="py-16" style="border-top: 1px solid var(--border-dim); border-bottom: 1px solid var(--border-dim);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 mb-8">
    <p
      class="text-center text-xs font-semibold uppercase tracking-widest"
      style="color: var(--text-tertiary);"
    >
      Connects with the tools you already use
    </p>
  </div>

  <div class="relative overflow-hidden" aria-label="Integration partners">
    <!-- Fade masks -->
    <div class="absolute left-0 top-0 bottom-0 w-32 z-10 pointer-events-none" style="background: linear-gradient(to right, var(--bg-primary), transparent);"></div>
    <div class="absolute right-0 top-0 bottom-0 w-32 z-10 pointer-events-none" style="background: linear-gradient(to left, var(--bg-primary), transparent);"></div>

    <div class="flex logo-track" style="width: max-content;" role="list">
      {doubled.map((logo) => (
        <div
          class="group flex flex-col items-center gap-2.5 mx-10 shrink-0"
          role="listitem"
          aria-label={logo.name}
        >
          <div
            class="w-11 h-11 flex items-center justify-center rounded-xl transition-all duration-300"
            style="
              background: var(--bg-surface);
              border: 1px solid var(--border-dim);
              color: var(--text-tertiary);
              filter: grayscale(1);
            "
            onmouseenter={`this.style.color='${logo.color}'; this.style.filter='grayscale(0)'; this.style.borderColor='rgba(255,255,255,0.12)'; this.style.background='var(--bg-card)';`}
            onmouseleave={`this.style.color='var(--text-tertiary)'; this.style.filter='grayscale(1)'; this.style.borderColor='var(--border-dim)'; this.style.background='var(--bg-surface)';`}
          >
            <span class="w-5 h-5 flex items-center" set:html={logo.svg} />
          </div>
          <span class="text-xs" style="color: var(--text-tertiary);">{logo.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
