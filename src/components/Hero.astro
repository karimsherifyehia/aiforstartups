---
---

<section class="relative min-h-[100dvh] flex items-center pt-32 pb-20 overflow-hidden">

  <!-- Ambient background orbs — fixed, GPU-accelerated -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute" style="
      top: -10%;
      right: -5%;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(79,142,247,0.07) 0%, transparent 70%);
      filter: blur(1px);
    "></div>
    <div class="absolute" style="
      bottom: 0;
      left: -10%;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(79,142,247,0.04) 0%, transparent 70%);
      filter: blur(1px);
    "></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 w-full">
    <div class="grid lg:grid-cols-[1fr_1.1fr] gap-16 items-center">

      <!-- Left — Copy -->
      <div class="reveal">

        <!-- Eyebrow -->
        <div class="mb-7">
          <span class="section-eyebrow">
            <span class="w-1.5 h-1.5 rounded-full" style="background: var(--accent); box-shadow: 0 0 6px var(--accent);"></span>
            E-commerce Ops OS · Egypt & MENA
          </span>
        </div>

        <!-- Headline -->
        <h1 class="display-xl mb-7" style="color: var(--text-primary); max-width: 14ch;">
          The fastest path from
          <span class="text-accent"> chaos</span>
          <br/>to shipped.
        </h1>

        <!-- Sub -->
        <p class="section-body mb-10" style="max-width: 44ch;">
          Unify orders, inventory, WhatsApp, and shipping in one place—then layer CRM, campaigns, and AI insights when you're ready.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-3 mb-12">
          <a
            href="https://wa.me/201040003090"
            class="btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Book a demo
            <span class="btn-icon">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
              </svg>
            </span>
          </a>
          <a
            href="https://wa.me/201040003090"
            class="btn-ghost"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="color: #25d366;" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
            </svg>
            WhatsApp us
          </a>
        </div>

        <!-- Stat pills -->
        <div class="flex flex-wrap gap-2">
          {[
            { label: 'Pick & Pack', stat: '30–60 min saved daily' },
            { label: 'Customers 2.0', stat: 'RFM · churn · LTV' },
            { label: 'Growth', stat: 'Campaigns & analytics' },
          ].map((item) => (
            <div
              class="flex items-center gap-2 px-3.5 py-2 rounded-xl text-xs font-medium"
              style="background: var(--bg-surface); border: 1px solid var(--border-dim);"
            >
              <span style="color: var(--accent);">✦</span>
              <span style="color: var(--text-primary);">{item.label}</span>
              <span style="color: var(--text-tertiary);">·</span>
              <span style="color: var(--text-secondary);">{item.stat}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right — product visual in double-bezel frame -->
      <div class="reveal" style="transition-delay: 120ms;">
        <div class="bezel-card">
          <div class="bezel-inner">
            <!-- Browser chrome bar -->
            <div
              class="flex items-center gap-2 px-4 py-2.5"
              style="background: rgba(8,8,13,0.9); border-bottom: 1px solid var(--border-dim);"
            >
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full" style="background: #ff5f57;"></div>
                <div class="w-2.5 h-2.5 rounded-full" style="background: #febc2e;"></div>
                <div class="w-2.5 h-2.5 rounded-full" style="background: #28c840;"></div>
              </div>
              <div
                class="flex-1 mx-3 h-5 rounded-full flex items-center justify-center text-xs"
                style="background: rgba(255,255,255,0.04); color: var(--text-tertiary); font-family: monospace; letter-spacing: 0;"
              >
                nexus.aiforstartups.io
              </div>
            </div>

            <!-- Video / screenshot -->
            <div class="relative" style="aspect-ratio: 16/10;">
              <video
                autoplay muted loop playsinline preload="none"
                poster="/screenshots/crm-overview.png"
                class="w-full h-full object-cover"
                aria-label="Nexus dashboard demo"
              >
                <source src="/videos/inbox-demo.mp4" type="video/mp4" />
              </video>
              <!-- Placeholder when no video loaded -->
              <div
                class="absolute inset-0 flex flex-col items-center justify-center gap-3"
                style="background: linear-gradient(145deg, #0c0c14, #111119);"
                id="hero-placeholder"
              >
                <div class="relative">
                  <!-- Pulsing ring -->
                  <div class="absolute inset-0 rounded-full animate-ping" style="background: rgba(79,142,247,0.15);"></div>
                  <div
                    class="relative w-14 h-14 rounded-full flex items-center justify-center"
                    style="background: rgba(79,142,247,0.1); border: 1px solid rgba(79,142,247,0.2);"
                  >
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="5 3 19 12 5 21 5 3"/>
                    </svg>
                  </div>
                </div>
                <p class="text-xs" style="color: var(--text-tertiary);">Product video placeholder</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating metric card -->
        <div
          class="absolute -bottom-5 -left-6 flex items-center gap-3 px-4 py-2.5 rounded-xl z-10"
          style="
            background: var(--bg-card);
            border: 1px solid var(--border-mid);
            box-shadow: 0 12px 40px rgba(0,0,0,0.5);
          "
        >
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(34,197,94,0.1);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>
            </svg>
          </div>
          <div>
            <p class="text-xs" style="color: var(--text-secondary);">Orders today</p>
            <p class="text-base font-bold number-tabular" style="color: var(--text-primary);">247 <span class="text-xs font-normal" style="color: #4ade80;">↑18%</span></p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const video = document.querySelector('#hero-placeholder')?.previousElementSibling as HTMLVideoElement | null;
  const placeholder = document.getElementById('hero-placeholder');
  if (video && placeholder) {
    video.addEventListener('playing', () => { placeholder.style.display = 'none'; });
  }
</script>
