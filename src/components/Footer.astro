---
const pages = [
  { label: 'Pricing', href: '#pricing' },
  { label: 'Privacy', href: '/privacy' },
  { label: 'Terms',   href: '/terms' },
  { label: 'Docs',    href: 'https://nexus-docs.aiforstartups.io', external: true },
];

const devLinks = [
  { label: 'API Reference', href: 'https://nexus-docs.aiforstartups.io/api/', external: true },
  { label: 'openapi.yaml',  href: 'https://nexus-docs.aiforstartups.io/openapi.yaml', external: true },
  { label: 'llms.txt',      href: '/llms.txt' },
];
---

<footer class="py-12" style="border-top: 1px solid var(--border-dim);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-8">

      <!-- Brand -->
      <div class="flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <rect width="28" height="28" rx="7" fill="var(--accent)"/>
          <path d="M8 14 L14 8 L20 14 L14 20 Z" fill="white" opacity="0.92"/>
          <path d="M11.5 14 L14 11.5 L16.5 14 L14 16.5 Z" fill="rgba(8,8,13,0.55)"/>
        </svg>
        <span class="text-sm font-semibold" style="color: var(--text-secondary);">
          © 2025 <a href="https://aiforstartups.io" style="color: var(--text-primary);" class="hover:underline">AiForStartups.io</a> · Nexus
        </span>
      </div>

      <!-- WhatsApp -->
      <a
        href="https://wa.me/201040003090"
        class="group flex items-center gap-2 text-sm transition-colors duration-200"
        style="color: var(--text-secondary);"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="group-hover:text-green-400 transition-colors" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
        </svg>
        Chat on WhatsApp · +20 104 000 3090
      </a>

      <!-- Nav links -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap items-center gap-1">
          {pages.map((p) => (
            <li>
              <a
                href={p.href}
                target={p.external ? '_blank' : undefined}
                rel={p.external ? 'noopener noreferrer' : undefined}
                class="text-sm px-3 py-1.5 rounded-lg transition-colors duration-150"
                style="color: var(--text-secondary);"
                onmouseenter="this.style.color='var(--text-primary)'; this.style.background='var(--bg-surface)';"
                onmouseleave="this.style.color='var(--text-secondary)'; this.style.background='transparent';"
              >
                {p.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Dev links -->
    <div style="border-top: 1px solid var(--border-dim);" class="pt-5">
      <p class="text-xs mb-2.5" style="color: var(--text-tertiary);">For developers & AI agents</p>
      <div class="flex flex-wrap gap-5">
        {devLinks.map((l) => (
          <a
            href={l.href}
            target={l.external ? '_blank' : undefined}
            rel={l.external ? 'noopener noreferrer' : undefined}
            class="text-xs transition-colors duration-150"
            style="color: var(--text-tertiary); font-family: 'Outfit', monospace;"
            onmouseenter="this.style.color='var(--accent-hi)';"
            onmouseleave="this.style.color='var(--text-tertiary)';"
          >
            {l.label}
          </a>
        ))}
      </div>
    </div>

  </div>
</footer>
