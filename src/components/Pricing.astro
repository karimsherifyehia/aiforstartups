---
interface Tier {
  name: string;
  tagline: string;
  price: string;
  period?: string;
  featured?: boolean;
  cta: { text: string; href: string };
  features: string[];
  limits?: string;
}

const tiers: Tier[] = [
  {
    name: 'Free',
    tagline: 'Explore what agents can do.',
    price: '$0',
    period: '/mo',
    cta: { text: 'Start free', href: 'https://nexus.aiforstartups.io' },
    limits: '50 contacts · 25 orders · 500 API calls/day',
    features: [
      'MCP server access (read-only)',
      'CRM — view contacts & history',
      'Orders — view & track',
      'Inventory — browse & check stock',
      'Agent self-registration',
      '1 AI agent',
      '30-day data retention',
    ],
  },
  {
    name: 'Starter',
    tagline: 'Your agent starts operating.',
    price: '$99',
    period: '/mo',
    cta: { text: 'Get started', href: 'https://nexus.aiforstartups.io?plan=starter' },
    limits: '500 contacts · 200 orders/mo · 1K messages',
    features: [
      'MCP full read + write access',
      'CRM — create & update contacts',
      'Orders — full lifecycle management',
      'Fulfillment & shipping workflows',
      'WhatsApp, Facebook & Instagram messaging',
      'Shopify sync',
      'Up to 2 AI agents',
    ],
  },
  {
    name: 'Growth',
    tagline: 'Scale your operations.',
    price: '$199',
    period: '/mo',
    featured: true,
    cta: { text: 'Start growing', href: 'https://nexus.aiforstartups.io?plan=growth' },
    limits: '5K contacts · unlimited orders · 5K messages',
    features: [
      'Everything in Starter',
      'Full MCP admin access',
      'Unlimited warehouses',
      'VoIP / PBX integration',
      'n8n automation workflows',
      'Competition intelligence',
      'Up to 5 AI agents',
      'Priority support',
    ],
  },
  {
    name: 'Scale',
    tagline: 'Full AI suite unlocked.',
    price: '$599',
    period: '/mo',
    cta: { text: 'Contact us', href: 'https://wa.me/201040003090' },
    limits: 'Unlimited everything · 20K messages',
    features: [
      'Everything in Growth',
      'AI sentiment analysis',
      'AI transcription & embeddings',
      'AI-powered CS dashboards',
      'Custom integrations',
      'Unlimited AI agents',
      'Dedicated onboarding',
      'SLA guarantee',
    ],
  },
];
---

<section id="pricing" class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="text-center mb-14 reveal">
      <span class="section-eyebrow mb-6 inline-block">Pricing</span>
      <h2 class="section-title mb-4">Start free. Upgrade when your agent needs to act.</h2>
      <p class="section-body mx-auto" style="max-width: 48ch;">
        Free tier is read-only — agents explore and prove their value. Upgrade when you're ready to let them operate.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 reveal-stagger">
      {tiers.map((tier) => (
        <div
          class={`flex flex-col rounded-2xl p-6 ${tier.featured ? 'ring-1 ring-[var(--accent)]' : ''}`}
          style={`background: ${tier.featured ? 'rgba(79,142,247,0.06)' : 'rgba(255,255,255,0.03)'}; border: 1px solid ${tier.featured ? 'rgba(79,142,247,0.3)' : 'var(--border-dim)'};`}
        >
          {tier.featured && (
            <div class="text-xs font-semibold mb-4 px-2 py-1 rounded-full text-center w-fit mx-auto"
              style="background: rgba(79,142,247,0.15); color: var(--accent);">
              Most popular
            </div>
          )}
          <div class="mb-5">
            <div class="text-sm font-semibold mb-1" style="color: var(--accent);">{tier.name}</div>
            <div class="text-xs mb-4" style="color: var(--text-muted);">{tier.tagline}</div>
            <div class="flex items-end gap-1">
              <span class="text-3xl font-bold" style="color: var(--text-primary);">{tier.price}</span>
              {tier.period && <span class="text-sm pb-1" style="color: var(--text-muted);">{tier.period}</span>}
            </div>
            {tier.limits && (
              <div class="text-xs mt-2 px-2 py-1 rounded-lg" style="background: rgba(255,255,255,0.04); color: var(--text-muted);">
                {tier.limits}
              </div>
            )}
          </div>

          <ul class="space-y-2.5 mb-8 flex-1">
            {tier.features.map((f) => (
              <li class="flex items-start gap-2 text-sm" style="color: var(--text-secondary);">
                <svg class="flex-shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                  style="color: var(--accent);">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>

          <a
            href={tier.cta.href}
            class={tier.featured ? 'btn-primary text-center' : 'btn-secondary text-center'}
            target={tier.cta.href.startsWith('http') ? '_blank' : undefined}
            rel="noopener noreferrer"
          >
            {tier.cta.text}
          </a>
        </div>
      ))}
    </div>

    <p class="text-center text-sm mt-8" style="color: var(--text-muted);">
      Additional AI agents: $10/agent/mo (Starter) · $5/agent/mo (Growth & Scale)
    </p>
  </div>
</section>
